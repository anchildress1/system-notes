{
  "name": "system-notes",
  "version": "2.5.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "postbuild": "if [ -d .next/standalone ]; then mkdir -p .next/standalone/.next && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public; fi",
    "start": "next start",
    "start:standalone": "[ -f .next/standalone/server.js ] && node .next/standalone/server.js || (echo 'Error: Standalone build not found. Run npm run build first.' && exit 1)",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint --config eslint.config.mjs .",
    "test": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "test:perf": "npm run build && lhci autorun --config=lighthouserc.mobile.json && lhci autorun --config=lighthouserc.desktop.json",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,js}\"",
    "clean": "rm -rf node_modules .next coverage",
    "postinstall": "[ -d .git ] && lefthook install || true"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "algoliasearch": "^5.48.0",
    "framer-motion": "^12.26.2",
    "instantsearch.css": "^8.9.0",
    "instantsearch.js": "^4.99.0",
    "next": "16.2.6",
    "pixi.js": "^8.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.5.0",
    "react-instantsearch": "^7.23.1",
    "react-instantsearch-nextjs": "^1.0.13",
    "react-markdown": "^10.1.0",
    "search-insights": "^2.17.3",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.27.2",
    "@rollup/rollup-linux-x64-gnu": "latest",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.18",
    "@tailwindcss/oxide-linux-x64-musl": "4.1.18",
    "lightningcss-linux-x64-gnu": "1.31.1",
    "lightningcss-linux-x64-musl": "1.31.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "16.2.6",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.17",
    "commitlint-plugin-rai": "^1.0.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "^27.4.0",
    "lefthook": "^2.0.15",
    "lighthouse": "^12.2.1",
    "prettier": "^3.8.0",
    "rollup": "^4.59.0",
    "tailwindcss": "^4",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "inquirer": "^8.2.7",
    "tmp": "^0.2.7",
    "qs": "^6.15.2",
    "mkdirp": "^1.0.4",
    "minimatch": "^9.0.9",
    "rollup": "^4.59.0",
    "next": "$next",
    "uuid": "^14.0.0",
    "postcss": ">=8.5.10 <9",
    "react": "$react",
    "react-dom": "$react-dom",
    "vite": "^8.0.16",
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0",
    "instantsearch.js": {
      "qs": "^6.15.2"
    }
  },
  "volta": {
    "node": "20.20.0"
  }
}
